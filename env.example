# ── LLM (Groq — free, 14 400 req/day) ────────────────────────────────────────
# Get key at: https://console.groq.com → API Keys → Create API key
GROQ_API_KEY=your_groq_api_key_here

# ── Google / Gemini (fallback if GROQ_API_KEY not set) ───────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cloudflare R2 (MP3 storage) ───────────────────────────────────────────────
# dash.cloudflare.com → R2 → your bucket → Settings → Account ID
R2_ACCOUNT_ID=your_cloudflare_account_id
# R2 → Manage R2 API Tokens → Create Token (Object Read & Write)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your-bucket-name
# R2 bucket → Settings → Public Access → enable → copy r2.dev subdomain
R2_PUBLIC_DOMAIN=pub-xxxxxxxxxxxxxxxx.r2.dev

# ── GitHub Pages RSS feed ────────────────────────────────────────────────────
# Create a NEW public repo, enable Pages: Settings → Pages → main branch
GITHUB_USERNAME=your_github_username
GITHUB_REPO=your-podcast-feed-repo
# github.com/settings/tokens → Generate new token → repo scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_FEED_PATH=feed.xml
# Leave blank to auto-use USERNAME.github.io/REPO
GITHUB_PAGES_DOMAIN=

# ── Podcast metadata ─────────────────────────────────────────────────────────
PODCAST_TITLE=The Latency Report
PODCAST_DESCRIPTION=The Latency Report is a daily AI-generated podcast covering the latest in artificial intelligence, software engineering, data science, and tech startups. Every episode is researched, written, and produced autonomously — delivering sharp, concise insights on what's moving in the world of technology. No fluff, just signal.
PODCAST_AUTHOR=Atharva Badgujar
PODCAST_EMAIL=atharvabadgujar58@gmail.com

# ── Scheduler ────────────────────────────────────────────────────────────────
# How often to generate a new podcast (cron format). Default: daily at 9am.
SCHEDULE_CRON=0 9 * * *

# Max podcasts per day (NotebookLM free tier = 3)
DAILY_LIMIT=3

# ── Topics ───────────────────────────────────────────────────────────────────
# Comma-separated seed categories. LLM picks specific topics from these.
TOPIC_CATEGORIES=AI and machine learning,software engineering,data science,cybersecurity,startups and tech

# ── App ──────────────────────────────────────────────────────────────────────
API_PORT=8000
LOG_LEVEL=INFO
